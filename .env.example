# Nexora Platform Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
POSTGRES_URL=postgresql://postgres:password@localhost:5432/nexora
REDIS_URL=redis://localhost:6379

# Kafka Configuration
KAFKA_BROKERS=localhost:9092

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Admin Configuration
ADMIN_PASSWORD=Nolag@zyra

# App Configuration
APP_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Service Ports
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=3001
FEED_SERVICE_PORT=3002
MESSAGING_SERVICE_PORT=3003
LIVESTREAM_SERVICE_PORT=3004
USER_SERVICE_PORT=3005
RECOMMENDATION_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
PAYMENT_SERVICE_PORT=3008
SEARCH_SERVICE_PORT=3009
AI_INFERENCE_SERVICE_PORT=3010

# AI Service Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration (for admin invitations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Environment
NODE_ENV=development
